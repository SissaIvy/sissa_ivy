{
  "name": "psyops-war-room",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "size:check": "node scripts/size_check.cjs dist 180",
  "size:report": "node scripts/size_report.cjs dist",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
